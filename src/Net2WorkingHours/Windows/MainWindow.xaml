<Window x:Class="Net2WorkingHours.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Net2WorkingHours"
        mc:Ignorable="d"
        Title="MainWindow" Height="768" Width="1024">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem x:Name="OpenCsvMenuItem" Header="CSV öffnen..." Click="OpenCsvMenuItem_Click" />
                <Separator />
                <MenuItem Header="Beenden" />
            </MenuItem>
        </Menu>
        <TabControl DockPanel.Dock="Top" x:Name="MainTabControl" Margin="10">

        </TabControl>        
    </DockPanel>
</Window>
